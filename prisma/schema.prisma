generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountType {
  FIDELITY_TAXABLE
  VZ_SAVINGS_401K
  VZ_LEGACY_401K
  VZ_EDP
}

enum InstrumentType {
  STOCK
  FUND
  CASH
}

enum ImportBatchStatus {
  PENDING
  COMPLETE
  PARTIAL
  FAILED
}

enum BenchmarkScope {
  ACCOUNT
  AGGREGATE_TOTAL
  AGGREGATE_ACTIONABLE
}

enum AgentType {
  RELATIVE_STRENGTH
  SECTOR_ROTATION
  RISK_MANAGER
  CANDIDATE_SCANNER
}

enum AgentRunStatus {
  RUNNING
  COMPLETE
  FAILED
}

model Account {
  id               String            @id @default(cuid())
  name             String
  type             AccountType
  institution      String
  /// External account identifier from the source institution's export (e.g. Fidelity's masked account number), used to match repeat imports to the right account.
  externalId       String?           @unique
  isLocked         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  holdings         Holding[]
  importBatches    ImportBatch[]
  benchmarkResults BenchmarkResult[]
  actionItems      ActionItem[]
  performances     AccountPerformance[]
}

model Instrument {
  id           String         @id @default(cuid())
  symbol       String         @unique
  name         String?
  type         InstrumentType @default(STOCK)
  expenseRatio Float?
  category     String?
  holdings     Holding[]
}

model ImportBatch {
  id               String            @id @default(cuid())
  account          Account           @relation(fields: [accountId], references: [id])
  accountId        String
  source           String
  fileName         String
  asOfDate         DateTime
  uploadedAt       DateTime          @default(now())
  status           ImportBatchStatus @default(PENDING)
  errorMessage     String?
  rowCount         Int               @default(0)
  holdings         Holding[]
  benchmarkResults BenchmarkResult[]

  @@index([accountId, asOfDate])
}

/// A single Fidelity-reported rolling-period return for one account, as
/// extracted from the weekly Performance PDF, alongside the S&P 500 return
/// for the same period so alpha can be read directly off this row instead of
/// recomputed from price history. One row per (accountId, period, asOfDate);
/// a re-upload for the same as-of date replaces the prior row for that period.
model AccountPerformance {
  id             String   @id @default(cuid())
  account        Account? @relation(fields: [accountId], references: [id])
  /// Null for the "Total Portfolio" aggregate row extracted from the Performance PDF's Total line — see isAggregate.
  accountId      String?
  /// True for the Total-row aggregate entry (accountId is null in that case). Postgres doesn't dedupe NULL accountId rows against the (accountId, period, asOfDate) unique index, so the aggregate row is upserted by application-level find-then-write instead — see performance-pdf/confirm/route.ts.
  isAggregate    Boolean  @default(false)
  /// "1m" | "3m" | "ytd" | "1y" | "3y" | "5y" | "life"
  period         String
  returnPct      Float
  sp500ReturnPct Float?
  alpha          Float?
  /// Only set when period is "life" — the start date Fidelity used for the account's life-of-data return.
  startDate      DateTime?
  asOfDate       DateTime
  createdAt      DateTime @default(now())

  @@unique([accountId, period, asOfDate])
  @@index([accountId, period])
  @@index([isAggregate, period])
}

model Holding {
  id               String      @id @default(cuid())
  account          Account     @relation(fields: [accountId], references: [id])
  accountId        String
  instrument       Instrument  @relation(fields: [instrumentId], references: [id])
  instrumentId     String
  importBatch      ImportBatch @relation(fields: [importBatchId], references: [id])
  importBatchId    String
  asOfDate         DateTime
  quantity         Float
  lastPrice        Float?
  currentValue     Float
  costBasisTotal   Float?
  averageCostBasis Float?
  percentOfAccount Float?
  /// Year-to-date return as a decimal fraction (e.g. 0.1046 for +10.46%), captured from a screenshot's balance overview when shown. Null when the source didn't report it.
  ytdReturn        Float?

  @@index([accountId, asOfDate])
  @@index([instrumentId])
}

/// Cached daily S&P 500 (^GSPC) closing prices, so benchmark math doesn't hit
/// Yahoo Finance on every request.
model BenchmarkPrice {
  id    String   @id @default(cuid())
  date  DateTime @unique
  close Float
}

/// A single computed portfolio-vs-S&P-500 comparison for one account or one
/// aggregate scope, over one rolling period, tied to the ImportBatch whose
/// snapshot supplied the "as of" end value.
model BenchmarkResult {
  id                  String         @id @default(cuid())
  importBatch         ImportBatch    @relation(fields: [importBatchId], references: [id])
  importBatchId       String
  scope               BenchmarkScope
  account             Account?       @relation(fields: [accountId], references: [id])
  accountId           String?
  /// "1y" | "3y" | "5y"
  period              String
  asOfDate            DateTime
  requestedStartDate  DateTime
  actualStartDate     DateTime?
  startValue          Float?
  endValue            Float?
  portfolioReturn     Float?
  sp500Return         Float?
  alpha               Float?
  insufficientHistory Boolean        @default(false)
  createdAt           DateTime       @default(now())

  @@index([scope, period, asOfDate])
  @@index([accountId, period])
}

/// One execution of a portfolio-analysis agent (e.g. Relative Strength),
/// storing its full structured output alongside the run's lifecycle state.
model AgentRun {
  id          String         @id @default(cuid())
  agentType   AgentType
  status      AgentRunStatus @default(RUNNING)
  startedAt   DateTime       @default(now())
  completedAt DateTime?
  output      Json?
  errorMessage String?
  actionItems ActionItem[]

  @@index([agentType, startedAt])
}

/// A single recommended action surfaced by an agent run, optionally rolled
/// up into a WeeklyBrief for the CIO summary view.
model ActionItem {
  id             String       @id @default(cuid())
  agentRun       AgentRun     @relation(fields: [agentRunId], references: [id])
  agentRunId     String
  priority       Int
  action         String
  rationale      String
  expectedImpact String?
  account        Account?     @relation(fields: [accountId], references: [id])
  accountId      String?
  weeklyBrief    WeeklyBrief? @relation(fields: [weeklyBriefId], references: [id])
  weeklyBriefId  String?
  createdAt      DateTime     @default(now())

  @@index([agentRunId])
  @@index([weeklyBriefId])
}

/// The CIO's weekly synthesized brief across all agent runs — one row per
/// week, linking the action items chosen for that week's summary.
model WeeklyBrief {
  id          String       @id @default(cuid())
  weekOf      DateTime     @unique
  cioSummary  String
  /// The CIO's taxable-account trim/sector-gap/momentum-add analysis for this week, shaped like CioTaxableOpportunities in lib/agents/cio.ts. Null when no taxable account data was available at synthesis time.
  taxableOpportunities Json?
  actionItems ActionItem[]
  recommendationOutcomes RecommendationOutcome[]
  createdAt   DateTime     @default(now())
}

/// Tracks what actually happened after a CIO recommendation was made — the
/// track record foundation for Phase 4 productization. Keyed by
/// (weeklyBriefId, actionItemIndex) rather than the ActionItem's own id,
/// since synthesizeWeeklyBrief() deletes and recreates that week's
/// ActionItem rows (and their ids) every time it resynthesizes; the index
/// within a given brief is the stable reference.
model RecommendationOutcome {
  id              String       @id @default(cuid())
  weeklyBrief     WeeklyBrief  @relation(fields: [weeklyBriefId], references: [id])
  weeklyBriefId   String
  /// 1-based position of the recommendation within that week's action item list (matches ActionItem.priority).
  actionItemIndex Int
  executed        Boolean      @default(false)
  executedDate    DateTime?
  /// Relative performance (symbol return minus S&P 500 return, decimal fraction) 30/90 days after executedDate. Null until enough time has elapsed, or when no ticker could be identified from the recommendation text.
  outcome30d      Float?
  outcome90d      Float?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([weeklyBriefId, actionItemIndex])
}

/// A tiny key-value store for cross-cutting notification state that doesn't
/// belong to any one domain row — e.g. the last time a Pushover push actually
/// went out, so a same-day re-run of the agent pipeline (multiple imports in
/// one day, a manual "Run Now") doesn't page the phone again.
model NotificationState {
  id         String   @id @default(cuid())
  key        String   @unique
  lastSentAt DateTime
}
